# syntax=docker/dockerfile:1.7
# rebuild: sentry-dsn-fix

# ── Stage 1: Build Flutter Web WASM ──
FROM ghcr.io/cirruslabs/flutter:3.41.6 AS build
ENV CI=true
WORKDIR /app

# Copy workspace
COPY pubspec.yaml ./
COPY apps/ ./apps/
COPY packages/ ./packages/
COPY bff/ ./bff/

# Resolve dependencies
RUN dart pub get --directory=apps/acdg_system

# Code generation (persistence first, then dependents)
RUN cd packages/persistence && dart run build_runner build --delete-conflicting-outputs
RUN cd bff/shared && dart run build_runner build --delete-conflicting-outputs
RUN cd apps/acdg_system && dart run build_runner build --delete-conflicting-outputs

# Build args for --dart-define-from-file
ARG OIDC_ISSUER
ARG OIDC_CLIENT_ID
ARG OIDC_SCOPES=openid\ profile\ email\ offline_access\ urn:zitadel:iam:org:project:roles
ARG OIDC_WEB_REDIRECT_URI
ARG OIDC_WEB_POST_LOGOUT_URI
ARG BFF_BASE_URL=/api
ARG SENTRY_DSN=
ARG APP_ENV=production
ARG SENTRY_RELEASE=
ARG SENTRY_DIST=

# Generate config.json at build-time (more robust than .env for WASM)
RUN cat <<EOF > apps/acdg_system/config.json
{
  "OIDC_ISSUER": "$OIDC_ISSUER",
  "OIDC_CLIENT_ID": "$OIDC_CLIENT_ID",
  "OIDC_SCOPES": "$OIDC_SCOPES",
  "OIDC_WEB_REDIRECT_URI": "$OIDC_WEB_REDIRECT_URI",
  "OIDC_WEB_POST_LOGOUT_URI": "$OIDC_WEB_POST_LOGOUT_URI",
  "BFF_BASE_URL": "$BFF_BASE_URL",
  "SENTRY_DSN": "$SENTRY_DSN",
  "APP_ENV": "$APP_ENV",
  "SENTRY_RELEASE": "$SENTRY_RELEASE",
  "SENTRY_DIST": "$SENTRY_DIST"
}
EOF

# BASE_HREF: set to /app/ when behind a gateway, or / for standalone
ARG BASE_HREF=/
RUN cd apps/acdg_system && flutter build web --wasm --release --pwa-strategy=none --base-href=$BASE_HREF --dart-define-from-file=config.json

# Cache busting: Flutter does not content-hash filenames, so we inject
# a build timestamp as query param into flutter_bootstrap.js references.
RUN BUILD_AT=$(date +%s) && \
    cd apps/acdg_system/build/web && \
    sed -i "s|main\.dart\.mjs|main.dart.mjs?v=${BUILD_AT}|g" flutter_bootstrap.js && \
    sed -i "s|main\.dart\.wasm|main.dart.wasm?v=${BUILD_AT}|g" flutter_bootstrap.js && \
    sed -i "s|main\.dart\.js|main.dart.js?v=${BUILD_AT}|g" flutter_bootstrap.js

# ── Stage 2: Serve with Caddy ──
FROM caddy:2-alpine
LABEL org.opencontainers.image.source="https://github.com/acdgbrasil/app-acdg-system"
LABEL org.opencontainers.image.description="ACDG Conecta Raros — Web Frontend"
LABEL org.opencontainers.image.licenses="Proprietary"

# Copy built WASM files
COPY --from=build /app/apps/acdg_system/build/web /srv

# Caddy config for Flutter Web WASM SPA
RUN cat > /etc/caddy/Caddyfile <<'CADDYFILE'
:80 {
    root * /srv
    file_server

    # Cross-origin isolation for Flutter WASM multi-threaded renderer (skwasm)
    header {
        Cross-Origin-Embedder-Policy "credentialless"
        Cross-Origin-Opener-Policy "same-origin"
    }

    # Gzip + Brotli compression
    encode gzip zstd

    # Immutable: fonts and images only (Flutter does not content-hash code files)
    @immutable path_regexp \.(woff2?|png|jpg|jpeg|svg|ico|gif|css)$
    header @immutable Cache-Control "public, immutable, max-age=31536000"

    # Flutter app code: never cache (Cloudflare CDN caches .js by default)
    @flutter_code path_regexp \.(wasm|mjs|js)$
    header @flutter_code Cache-Control "no-store, must-revalidate"

    # Entry points: never cache
    @entrypoints path / /index.html /version.json /flutter_bootstrap.js /manifest.json
    header @entrypoints Cache-Control "no-store, must-revalidate"

    # SPA fallback
    try_files {path} /index.html

    # Health check
    handle /healthz {
        respond "ok" 200
    }

    # Cache invalidation (called by version-gate JS on deploy detection)
    handle /cache-invalidate {
        header Cache-Control "no-store"
        header Clear-Site-Data "\"cache\""
        respond "cache cleared" 200
    }
}
CADDYFILE

EXPOSE 80
CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile"]
